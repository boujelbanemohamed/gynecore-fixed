generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DOCTOR
  ASSISTANT
  SECRETARY
  PATIENT
  SUPERADMIN
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  PENDING
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
  NO_SHOW
}

enum CertificateType {
  APTITUDE
  MEDICAL_REST
  PREGNANCY_WORK
  MATERNITY_LEAVE
  RETURN_TO_WORK
  POST_OPERATIVE
}

enum ConsultationType {
  FIRST_VISIT
  FOLLOW_UP
  EMERGENCY
  ANNUAL_CHECKUP
  PRENATAL
  POSTNATAL
}

model User {
  unavailableSlots UnavailableSlot[]
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           Role
  firstName      String
  lastName       String
  phone          String?
  isActive       Boolean  @default(true)
  cinNumber      String?
  doctorId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  licenseNumber  String?
  specialization String?
  rppsNumber    String?
  clinicName    String?
  address       String?
  city          String?
  postalCode    String?
  logo          String?
  services      String?
  country       String?
  patient         Patient?
  appointments    Appointment[] @relation("DoctorAppointments")
  managedPatients Patient[]     @relation("DoctorPatients")
  resetTokens      PasswordResetToken[]
  secretary       User?    @relation("DoctorSecretary", fields: [doctorId], references: [id], onDelete: SetNull)
  secretaries    User[]   @relation("DoctorSecretary")

  smtpConfigs      SmtpConfig[]

  @@map("users")
}

model Patient {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId            String?
  doctor              User?     @relation("DoctorPatients", fields: [doctorId], references: [id])
  isArchived          Boolean   @default(false)
  dateOfBirth         DateTime
  bloodType           String?
  address             String?
  city                String?
  postalCode          String?
  country             String    @default("France")
  emergencyContact    String?
  emergencyPhone      String?
  allergies           String?
  chronicDiseases     String?
  familyHistory       String?
  currentMedications  String?
  lastMenstrualPeriod DateTime?
  numberOfPregnancies Int       @default(0)
  numberOfDeliveries  Int       @default(0)
  contraceptionMethod String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  consultations       Consultation[]
  prescriptions       Prescription[]
  appointments        Appointment[]
  documents           Document[]
  certificates         Certificate[]
  medicalLetters       MedicalLetter[]

  clinicalExams         ClinicalExam[]
  @@map("patients")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model Consultation {
  id             String           @id @default(cuid())
  patientId      String
  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date           DateTime
  type           ConsultationType @default(FIRST_VISIT)
  chiefComplaint String?
  symptoms       String?
  clinicalExam   String?
  diagnosis      String?
  treatment      String?
  notes          String?
  weight         Float?
  bloodPressure  String?
  temperature    Float?
  nextVisit      DateTime?
  isConfidential Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  prescriptions  Prescription[]

  @@index([date])
  @@map("consultations")
}

model Prescription {
  id             String        @id @default(cuid())
  patientId      String
  patient        Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  date           DateTime      @default(now())
  medications    Json
  notes          String?
  isValid        Boolean       @default(true)
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("prescriptions")
}

model Appointment {
  id        String            @id @default(cuid())
  patientId String
  patient   Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId  String
  doctor    User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  startTime DateTime
  endTime   DateTime
  type      ConsultationType  @default(FIRST_VISIT)
  status    AppointmentStatus @default(SCHEDULED)
  reason    String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([doctorId])
  @@index([startTime])
  @@map("appointments")
}

model Document {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name      String
  type      String
  url       String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@map("documents")
}

model Certificate {
  id             String           @id @default(cuid())
  patientId      String
  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type           CertificateType
  date           DateTime         @default(now())
  content        Json
  isValid        Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@map("certificates")
}


model MedicalLetter {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type       String
  recipient  String
  subject    String
  content    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("medical_letters")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userRole  String
  action    String
  resource  String
  resourceId String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}

model UnavailableSlot {
  id        String   @id @default(uuid())
  doctorId  String
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([startTime, endTime])
}


model ClinicalExam {
  id                   String   @id @default(cuid())
  patientId            String
  patient              Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  date                 DateTime @default(now())
  weight               Float?
  height               Float?
  heartRate            Int?
  bloodPressure        String?
  temperature          Float?
  generalState         String?
  conjonctives         String?
  oedemes              String?
  cardiacAuscultation  String?
  pulmonaryAuscultation String?
  abdomen              String?
  uterusState          String?
  uterineHeight        Float?
  presentation         String?
  bcf                  String?
  adnexa               String?
  cervixAspect         String?
  vaginalDischarge     String?
  dilatation           String?
  effacement           String?
  consistency          String?
  presentationHeight   String?
  breastExam           String?
  clinicalConclusion   String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("clinical_exams")
}

model SmtpConfig {
  id            String   @id @default(uuid())
  doctorId      String   @unique
  doctor        User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  smtpHost      String   @default("smtp.gmail.com")
  smtpPort      Int      @default(587)
  smtpSecure    Boolean  @default(false)
  smtpUser      String   @default("")
  smtpPass      String   @default("")
  smtpFromName  String   @default("GyneCare")
  smtpFromEmail String   @default("")
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("smtp_configs")
}
