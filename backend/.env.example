# ──────────────────────────────────────────────────────────────
# GyneCare Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter .env dans Git
# ──────────────────────────────────────────────────────────────

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gynecare_db"

# JWT — OBLIGATOIRE en production (min 32 caractères aléatoires)
# Générer avec : openssl rand -base64 48
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_48"
JWT_EXPIRES_IN="24h"
JWT_PATIENT_EXPIRES_IN="12h"

# Serveur
PORT=4000
NODE_ENV=development

# CORS — URL exacte du frontend (sans slash final)
CORS_ORIGIN="http://localhost:3000"
