# ── Base de données ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gynecare_db

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_EXPIRES_IN=24h
JWT_PATIENT_EXPIRES_IN=7d

# ── Serveur ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── SMTP (optionnel, configurable aussi via superadmin) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=GyneCare
SMTP_FROM_EMAIL=your-email@gmail.com

# ── Sécurité ─────────────────────────────────────────────────────
ENCRYPTION_KEY=change_me_to_a_random_32_char_string
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ── Google Calendar OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/doctor/google-calendar/callback
